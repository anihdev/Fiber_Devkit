# CKB testnet RPC endpoint used by funding support scripts.
CKB_RPC_URL=https://testnet.ckb.dev/rpc

# Funded CKB testnet treasury private key used only by `pnpm fund:nodes`.
CKB_PRIVATE_KEY=REPLACE_WITH_TESTNET_PRIVATE_KEY

# Target testnet CKB balance per generated node key.
DEVKIT_NODE_FUND_CKB=500
